# ── WhatsApp Business API ─────────────────────────────────────────────────────
# Get from https://developers.facebook.com → Your App → WhatsApp → API Setup
WHATSAPP_TOKEN=your_permanent_access_token_here
WHATSAPP_PHONE_ID=your_phone_number_id_here

# Verification token — set this to any secret string, then enter same in Meta dashboard
WHATSAPP_VERIFY_TOKEN=thalihouse_verify

# Owner's WhatsApp number (receives new order / reservation alerts)
OWNER_WHATSAPP_NUMBER=+918888377788

# ── Frontend origin ───────────────────────────────────────────────────────────
FRONTEND_URL=https://your-thalihouse-domain.com
