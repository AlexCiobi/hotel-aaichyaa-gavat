# ═══════════════════════════════════════════════════════════════════════════════
# THALI HOUSE — PRODUCTION ENVIRONMENT VARIABLES
# Copy this file, fill in the values, and never commit the filled version to git.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Supabase (Frontend) ───────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Admin Panel ───────────────────────────────────────────────────────────────
# Change these before going live! Use a strong password.
VITE_ADMIN_EMAIL=admin@thalihouse.com
VITE_ADMIN_PASSWORD=ChangeThisToAStrongPassword!

# ── Backend API (FastAPI) ─────────────────────────────────────────────────────
# URL where your FastAPI backend is deployed (Railway, Render, etc.)
VITE_API_URL=https://api.thalihouse.com

# ── Razorpay ──────────────────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
# Use rzp_test_* for testing, rzp_live_* for production
VITE_RAZORPAY_KEY_ID=rzp_live_your_key_here

# ── WhatsApp Business API (Backend .env) ──────────────────────────────────────
# Get from: https://developers.facebook.com → Your App → WhatsApp → API Setup
# Step 1: Create a Meta Developer account
# Step 2: Create an App → Add WhatsApp product
# Step 3: Create a System User and generate a permanent token
WHATSAPP_TOKEN=EAAxxxxxxxxxxxx
WHATSAPP_PHONE_ID=1234567890          # Found in WhatsApp → Phone Numbers

# Token you choose — must match what you enter in Meta webhook settings
WHATSAPP_VERIFY_TOKEN=thalihouse_webhook_verify_2024

# Owner's WhatsApp number (gets alerts for new orders + reservations)
OWNER_WHATSAPP_NUMBER=+918888377788

# ── Email — Resend (Supabase Edge Function secret) ────────────────────────────
# Get from: https://resend.com → API Keys (free: 100 emails/day)
# Add as Edge Function secret in Supabase Dashboard → Edge Functions
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=orders@thalihouse.in       # Must be a verified domain in Resend

# ── Frontend Origin (Backend CORS) ───────────────────────────────────────────
FRONTEND_URL=https://thalihouse.com
